# URL de l'API (vide en dev = proxy Vite vers VITE_API_PROXY_TARGET)
VITE_API_BASE_URL=

# Cible du proxy Vite (npm run dev uniquement)
VITE_API_PROXY_TARGET=http://127.0.0.1:5000

# Exemple déploiement : URL réelle de l'API Flask (alwaysdata, etc.)
# VITE_API_BASE_URL=https://votre-api.example.com
